{
  "name": "jwt-studio",
  "version": "1.10.1",
  "description": "A studio for working with JSON Web Tokens",
  "author": "MiguelRipoll23",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MiguelRipoll23/jwt-studio.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "node ./node_modules/typescript-7/bin/tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build": "node ./node_modules/typescript-7/bin/tsc -b && vite build && electron-builder"
  },
  "build": {
    "appId": "com.jwt-app.studio",
    "productName": "JWT Studio",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "MiguelRipoll23",
      "repo": "jwt-studio"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/*.map",
      "!**/*.d.ts"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}.Setup.${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.png"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "typescript": "npm:@typescript/typescript6@^6.0.1",
    "typescript-7": "npm:typescript@^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-electron": "^1.1.0"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "sharp@0.34.5": true,
    "@swc/core@1.15.43": true,
    "electron@40.10.6": true,
    "esbuild@0.28.1": true
  }
}
