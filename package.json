{
  "name": "jwt-studio",
  "version": "1.9.2",
  "description": "A studio for working with JSON Web Tokens",
  "author": "MiguelRipoll23",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MiguelRipoll23/jwt-studio.git"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:build": "tsc -b && vite build && electron-builder"
  },
  "build": {
    "appId": "com.jwt-app.studio",
    "productName": "JWT Studio",
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "MiguelRipoll23",
      "repo": "jwt-studio"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/*.map",
      "!**/*.d.ts"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName}.Setup.${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.png"
    }
  },
  "dependencies": {
    "@openai/apps-sdk-ui": "^0.2.1",
    "jose": "^6.1.3",
    "lucide-react": "^1.11.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.13.1",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0"
  }
}
